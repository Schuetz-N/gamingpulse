# GamingPulse - Environment Variables
# Copy this file to .env and fill in all values.
# .env is not committed to the repository.

# Database
# Path to the SQLite file inside the backend container
DB_PATH=/app/data/gamingpulse.db

# n8n
# Password for n8n basic auth (admin user)
N8N_PASSWORD=

# Telegram
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Target channel ID (negative number for public channels, e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=

# Groq
# API key from console.groq.com
GROQ_API_KEY=

# API Security
# Shared secret between n8n and the backend - generate with: openssl rand -hex 32
API_AUTH_TOKEN=

# n8n URL - only set if different from the default (http://n8n:5678)
# GAMINGPULSE_N8N_URL=http://n8n:5678