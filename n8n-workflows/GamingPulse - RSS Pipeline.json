    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Parse Feed Items').item.json;\nconst response = $('LLM Summarize').item.json;\nconst category = original.category || 'gaming';\nconst title = original.title || 'No title';\nconst link = original.link || '';\nconst hashtag = { gaming: '#gaming', hardware: '#hardware', proton: '#proton' }[category] || '#gaming';\nconst emoji = { gaming: '🎮', hardware: '🔧', proton: '🐧' }[category] || '🎮';\nlet msg;\nif (original.skipOllama) {\n  msg = `${hashtag}\\n\\n${emoji} ${title}\\n\\n${link}`;\n} else {\n  let summary = (response.summary || 'No summary available').trim();\n  \n  summary = summary\n    .replace(/^(here is|here's|here are)[^:]*:\\s*/i, '')\n    .replace(/^(summary|overview|in summary)[^:]*:\\s*/i, '')\n    .replace(/^(the article|this article|this news)[^.]*\\.\\s*/i, '')\n    .replace(/^\\s*\\n+/g, '')\n    .trim();\n  msg = `${hashtag}\\n\\n${emoji} *${title}*\\n\\n${summary}\\n\\n${link}`;\n}\nreturn { json: { message: msg } };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
